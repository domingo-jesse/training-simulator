# Copy this file to .streamlit/secrets.toml and replace placeholder values.
# For Supabase/Postgres persistence, set one of these DSN variables:
DATABASE_URL = "postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"
# SUPABASE_DB_URL = "postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"
# SUPABASE_DATABASE_URL = "postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"

# Optional Supabase REST credentials (not used by this app's SQL data layer)
SUPABASE_URL = "https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_KEY = "YOUR_SUPABASE_ANON_OR_SERVICE_KEY"
